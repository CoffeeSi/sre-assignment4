DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/app_db

POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=app_db

REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=dev-secret-key-change-in-production

JWT_ALGORITHM=HS256

JWT_EXPIRE_HOURS=24

SERVICE_PORT=8000

AUTH_SERVICE_URL=http://auth-service:8000
USER_SERVICE_URL=http://user-service:8001
PRODUCT_SERVICE_URL=http://product-service:8002
ORDER_SERVICE_URL=http://order-service:8003
CHAT_SERVICE_URL=http://chat-service:8005
API_GATEWAY_URL=http://api-gateway:8080

INSTANCE_IP=127.0.0.1

ENVIRONMENT=development

LOG_LEVEL=INFO

JSON_LOGGING=true

PROMETHEUS_PORT=9090

GRAFANA_PORT=3000

UPSTREAM_TIMEOUT=30

REQUEST_TIMEOUT=30

DB_POOL_SIZE=10

DB_MAX_OVERFLOW=5

DB_POOL_MIN_SIZE=1

DB_POOL_MAX_SIZE=20

REDIS_POOL_SIZE=10

HEALTH_CHECK_INTERVAL=10

HEALTH_CHECK_TIMEOUT=5

HEALTH_CHECK_RETRIES=3

HEALTH_CHECK_START_PERIOD=15

RESTART_POLICY=unless-stopped

RESTART_DELAY=5

RESTART_MAX_ATTEMPTS=3

SERVICE_REPLICAS=3

ORDER_SERVICE_REPLICAS=5

API_GATEWAY_REPLICAS=3

ORDER_SERVICE_CPU_LIMIT=1.5

ORDER_SERVICE_MEMORY_LIMIT=1G

ORDER_SERVICE_CPU_RESERVATION=0.5

ORDER_SERVICE_MEMORY_RESERVATION=256M

API_GATEWAY_CPU_LIMIT=1.0

API_GATEWAY_MEMORY_LIMIT=512M

API_GATEWAY_CPU_RESERVATION=0.25

API_GATEWAY_MEMORY_RESERVATION=128M

POSTGRES_CPU_LIMIT=1.0

POSTGRES_MEMORY_LIMIT=1G

POSTGRES_CPU_RESERVATION=0.25

POSTGRES_MEMORY_RESERVATION=256M

POSTGRES_MAX_CONNECTIONS=200

POSTGRES_SHARED_BUFFERS=256MB

POSTGRES_WORK_MEM=8MB

POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
